# Swahilipot Hub Portal — Environment Variables
#
# ── Testing email locally ─────────────────────────────────────────────────
# Leave DJANGO_EMAIL_HOST_USER and DJANGO_EMAIL_HOST_PASSWORD empty (or
# commented out) to use CONSOLE mode:
#   - No real email is sent.
#   - The password-reset link is printed to the terminal instead.
#   - Copy and paste it into your browser to complete the reset.
#
# ── Setting up real email sending ─────────────────────────────────────────
# Fill in YOUR Gmail address and a Gmail App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (must be ON)
#   3. Visit https://myaccount.google.com/apppasswords
#   4. Create one for: App = Mail, Device = Windows Computer
#   5. Google shows a 16-character password (e.g. abcd efgh ijkl mnop)
#   6. Paste it below WITHOUT spaces, then restart the server
#
# DJANGO_EMAIL_HOST_USER=your-gmail@gmail.com
# DJANGO_EMAIL_HOST_PASSWORD=paste16charpasswordhere

DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Full public URL used to generate absolute QR code URLs.
# When running locally this should be your local address.
# The portal works fully without any public tunnel.
DJANGO_SITE_BASE_URL=http://127.0.0.1:8000

# ── Google Form integration ───────────────────────────────────────────────────
# Paste your Google Form /viewform URL here:
GOOGLE_FORM_BASE_URL=https://docs.google.com/forms/d/e/1FAIpQLSedV4ca8NSItkayTczjXGSQDETcUDpt4u936FxE9ul1rsVl4g/viewform

# Pre-fill field keys extracted from your prefilled link:
# entry.87039877  → Event ID field
# entry.1265070359 → Event Name / Title field
GOOGLE_FORM_EVENT_ID_FIELD=entry.87039877
GOOGLE_FORM_EVENT_NAME_FIELD=entry.1265070359
