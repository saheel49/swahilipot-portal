# ── Swahilipot Hub Portal — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Django
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Full public URL — used to generate absolute QR code links.
# Set to your tunnel/server URL so phones can reach the portal:
#   Cloudflare Tunnel: DJANGO_SITE_BASE_URL=https://random-name.trycloudflare.com
#   ngrok:             DJANGO_SITE_BASE_URL=https://abc123.ngrok-free.app
#   Production:        DJANGO_SITE_BASE_URL=https://portal.swahilipothub.co.ke
DJANGO_SITE_BASE_URL=http://127.0.0.1:8000

# CSRF trusted origins — add your tunnel/server URL when using a reverse proxy.
# Comma-separated, must include the full scheme (https://...)
# Example: DJANGO_CSRF_TRUSTED_ORIGINS=https://random-name.trycloudflare.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Database (leave blank to use SQLite in development)
# DATABASE_URL=postgres://user:password@localhost:5432/swahilipot_portal

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────
# Required for password reset emails to be actually sent.
# If left blank, reset links are printed to the terminal instead (great for testing).
#
# ── Testing without SMTP ──────────────────────────────────────────────────
# Leave DJANGO_EMAIL_HOST_USER and DJANGO_EMAIL_HOST_PASSWORD empty (or remove
# them from .env entirely).  The server falls back to "console" mode:
#   - Go to the "Forgot password?" page and enter any registered email address.
#   - Look at the terminal running "python manage.py runserver".
#   - You will see the full reset email printed there, including the reset link.
#   - Copy that link and paste it into your browser — it works exactly like
#     a real email.
#
# ── Setting up real SMTP (Gmail) ─────────────────────────────────────────
#   1. Sign in to https://myaccount.google.com
#   2. Go to Security → 2-Step Verification (enable it if not already on)
#   3. Search for "App passwords" in the search bar
#   4. Select "Mail" and "Windows Computer", click Generate
#   5. Copy the 16-character password shown — use it as DJANGO_EMAIL_HOST_PASSWORD
#   6. Fill in both variables below with YOUR Gmail address and the App Password.
#
DJANGO_EMAIL_HOST_USER=your-gmail@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
